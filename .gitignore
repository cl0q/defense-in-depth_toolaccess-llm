# ---------------------------------------------------------------------------
# Python virtual environments (built per-machine, never committed)
# ---------------------------------------------------------------------------
venv/
gateway/venv/
redteam/pyrit_venv/
**/.venv/
**/venv/

# ---------------------------------------------------------------------------
# Python bytecode / caches
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ---------------------------------------------------------------------------
# Secrets & local config (NEVER commit)
# ---------------------------------------------------------------------------
.env
.env.*
creds.txt

# ---------------------------------------------------------------------------
# Runtime artifacts & experiment output (regenerated by the stack)
# ---------------------------------------------------------------------------
analysis/artifacts/
analysis/report.json
analysis/power_report.json
power_log.jsonl
power_log.jsonl.bak
idle_baseline.jsonl
smoketest.out
sweep_full.log
*.log

# PyRIT memory databases
**/pyrit.db
*.duckdb

# ---------------------------------------------------------------------------
# OS / editor cruft
# ---------------------------------------------------------------------------
.DS_Store
Thumbs.db
~$*
